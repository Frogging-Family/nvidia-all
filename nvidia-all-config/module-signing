#!/usr/bin/env bash

# Stop the script at any encountered error
set -e

_sign_module() {
  local _signed_any=0

  while IFS= read -r -d '' _kbuild; do
    local _kernel="${_kbuild%/build}"
    _kernel="${_kernel##*/}"
    local _file="${_kbuild}/scripts/sign-file"
    local _config="${_kbuild}/.config"

    if [[ ! -x "${_file}" ]] || [[ ! -r "${_config}" ]]; then
      echo ":: module-signing: skipped ${_kernel}: build metadata missing"
      continue
    fi

    local _key
    _key=$(grep -Po 'CONFIG_MODULE_SIG_KEY="\K[^"]*' "${_config}" 2>/dev/null || true)
    [[ -n "${_key}" ]] || _key="certs/signing_key.pem"
    [[ "${_key}" =~ ^/ ]] || _key="${_kbuild}/${_key}"
    local _cert="${_kbuild}/certs/signing_key.x509"
    local _hash_algo
    _hash_algo=$(grep -Po 'CONFIG_MODULE_SIG_HASH="\K[^"]*' "${_config}" 2>/dev/null \
      || echo sha256)

    if [[ ! -r "${_key}" ]] || [[ ! -r "${_cert}" ]]; then
      echo ":: module-signing: skipped ${_kernel}: signing key not readable"
      continue
    fi

    local _changed=0

    while IFS= read -r -d '' _mod; do
      local _plain_mod="${_mod}" _compression=""

      case "${_mod}" in
        *.ko.zst)
          zstd -d --rm -f -q "${_mod}"
          _plain_mod="${_mod%.zst}"
          _compression="zst"
          ;;
        *.ko.xz)
          xz -d -f "${_mod}"
          _plain_mod="${_mod%.xz}"
          _compression="xz"
          ;;
        *.ko.gz)
          gzip -d -f "${_mod}"
          _plain_mod="${_mod%.gz}"
          _compression="gz"
          ;;
      esac

      "${_file}" "${_hash_algo}" "${_key}" "${_cert}" "${_plain_mod}"

      case "${_compression}" in
        zst) zstd -19 --rm -f -q "${_plain_mod}" ;;
        xz) xz -f "${_plain_mod}" ;;
        gz) gzip -n -f "${_plain_mod}" ;;
      esac

      _changed=1
      _signed_any=1
    done < <(find "/usr/lib/modules/${_kernel}" -type f \
      \( -name 'nvidia*.ko' -o -name 'nvidia*.ko.zst' -o -name 'nvidia*.ko.xz' -o -name 'nvidia*.ko.gz' \) \
      -print0)

    if (( _changed )); then
      depmod "${_kernel}"
    fi
  done < <(find /usr/lib/modules -mindepth 2 -maxdepth 2 -type d -name build -print0)

  if (( _signed_any == 0 )); then
    echo ":: module-signing: skipped — no installed NVIDIA modules found"
  fi
}

main() {
  case "${1:-}" in
    "")
      _sign_module
      ;;
    *)
      echo "Usage: module-signing" >&2
      echo "  Signs installed NVIDIA kmod modules with the kernel/system signing key." >&2
      return 1
      ;;
  esac
}

main "$@"


#!/bin/bash

# debuginfo
#set -x

# Active driver series
_current_nvidia=("595" "580" "570" "470")

# Vulkan dev series — pinned manually
_vulkandev_version="595.44.07"

# EOL / legacy driver series
_eol_nvidia=(
  "590 series: 590.48.01"
  "575 series: 575.64.05"
  "565 series: 565.77"
  "560 series: 560.35.03"
  "555 series: 555.58.02"
  "550 series: 550.135"
  "545 series: 545.29.06"
  "535 series: 535.309.01"
  "530 series: 530.41.03"
  "525 series: 525.147.05"
  "520 series: 520.56.06"
  "515 series: 515.86.01"
  "510 series: 510.85.02"
  "495 series: 495.46"
  "465 series: 465.31"
  "460 series: 460.91.03"
  "455 series: 455.45.01"
  "450 series: 450.119.03"
  "440 series: 440.100  (kernel 5.8 or lower)"
  "435 series: 435.21   (kernel 5.6 or lower)"
  "430 series: 430.64   (kernel 5.5 or lower)"
  "418 series: 418.113  (kernel 5.5 or lower)"
  "415 series: 415.27   (kernel 5.4 or lower)"
  "410 series: 410.104  (kernel 5.5 or lower)"
  "396 series: 396.54   (kernel 5.3 or lower, 5.1 or lower recommended)"
)

# Extract the version number from an EOL label
_ver_from_entry() {
  grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' <<< "$1" | tail -1
}

# Fetch latest driver version per active series, populates _nvidia_ver_map.
_define_nvidia_versions() {
  [[ -v _nvidia_ver_map ]] && return 0

  typeset -gA _nvidia_ver_map
  local _listing _series _latest

  msg2 "Please make sure you have the corresponding kernel headers installed for each kernel on your system!\n"
  msg2 "Fetching latest NVIDIA driver versions..."
  _listing=$(curl -s --max-time 15 \
    https://download.nvidia.com/XFree86/Linux-x86_64/ \
    | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?/' | tr -d '/')

  if [[ -z "$_listing" ]]; then
    error "Could not fetch NVIDIA driver listing (network error or timeout)."
    exit 1
  fi

  for _series in "${_current_nvidia[@]}"; do
    _latest=$(echo "$_listing" | grep -E "^${_series}\." | sort -V | tail -1)
    [[ -n "$_latest" ]] && _nvidia_ver_map[$_series]="$_latest"
  done
}

_prompt_from_array() {
  # Prompt from array; set _default_index for default on empty input.

  unset _selected_index
  local _N=$(($# - 1))
  local _index=0
  for _value in "$@"; do
    if [ "$_index" = "$_default_index" ]; then
      plain "  > ${_index}) ${_value}"
    else
      plain "    ${_index}) ${_value}"
    fi
    _index=$((_index + 1))
  done
  while true; do
    read -rp "[0-${_N}]: "
    if [[ -z "$REPLY" && -n "$_default_index" ]]; then
      _selected_index="$_default_index"
      break
    elif [[ "$REPLY" =~ ^[0-9]+$ && 0 -le "$REPLY" && "$REPLY" -le $_N ]]; then
      _selected_index="$REPLY"
      break
    else
      echo "Wrong selection: select any number in 0-${_N}"
    fi
  done
  local _natural_index=$((_selected_index + 1))
  _selected_value="${!_natural_index}"
  plain "Selected: ${_selected_value}"
}

# Older driver series
_select_older_driver() {
  local -a _labels=()
  local -a _versions=()
  local _e

  for _e in "${_eol_nvidia[@]}"; do
    _labels+=( "$_e" )
    _versions+=( "$(_ver_from_entry "$_e")" )
  done

  plain "Which legacy driver version do you want?"
  _default_index=0
  _prompt_from_array "${_labels[@]}"
  _driver_version="${_versions[$_selected_index]}"
  _driver_branch="regular"
}

# Custom driver version
_select_custom_driver() {
  local _branch_choice
  plain "Which branch do you want?"
  plain "  > 1) Stable or regular beta"
  plain "    2) Vulkan dev"
  read -rp "[1-2]: " _branch_choice
  if [[ "$_branch_choice" = "2" ]]; then
    _driver_branch="vulkandev"
    read -rp "Type the desired version number (format: xxx.xx.xx): " _driver_version
  else
    _driver_branch="regular"
    read -rp "Type the desired version number (format: xxx.xx.xx or xxx.xxx or xxx.xx): " _driver_version
  fi
}

# Version and branch
_set_driver_version() {
  local _series _ver

  # resolve versions from NVIDIA download index
  _define_nvidia_versions

  # Build driver menu
  local -a _DRIVERS=()
  local _DRIVER_VULKAN_IDX=0
  local _DRIVER_LATEST_IDX=1

  _DRIVERS+=( "Vulkan dev: ${_vulkandev_version}|vulkandev" )
  for _series in "${_current_nvidia[@]}"; do
    _ver="${_nvidia_ver_map[$_series]:-}"
    if [[ -z "$_ver" ]]; then
      warning "Could not resolve version for series $_series — skipping."
      continue
    fi
    local _suffix=""
    [[ "$_series" = "470" ]] && _suffix=" (LTS kernel recommended)"
    _DRIVERS+=( "${_series} series: ${_ver}${_suffix}|regular" )
  done
  _DRIVERS+=( "Older series|older" "Custom version (396.xx or higher)|custom" )

  # Resolve 'latest' alias
  if [[ "$_driver_version" = "latest" ]]; then
    case "${_driver_branch:-}" in
      regular)
        _driver_version="$(_ver_from_entry "${_DRIVERS[$_DRIVER_LATEST_IDX]}")"
        ;;
      vulkandev)
        _driver_version="$_vulkandev_version"
        ;;
      *)
        error '"latest" driver specified without valid _driver_branch. Set _driver_branch in customization.cfg.'
        return 1
        ;;
    esac
    echo "_driver_version='$_driver_version'" >> "$_where/BIG_UGLY_FROGMINER"
    echo "_driver_branch='$_driver_branch'"   >> "$_where/BIG_UGLY_FROGMINER"
    return 0
  fi

  # Version provided in config
  if [[ -n "$_driver_version" && "$_driver_version" != "custom" ]]; then
    if [[ -z "${_driver_branch:-}" ]]; then
      if [[ "$_driver_version" = "$_vulkandev_version" ]]; then
        _driver_branch="vulkandev"
      else
        _driver_branch="regular"
      fi
    fi
    echo "_driver_version='$_driver_version'" >> "$_where/BIG_UGLY_FROGMINER"
    echo "_driver_branch='$_driver_branch'"   >> "$_where/BIG_UGLY_FROGMINER"
    return 0
  fi

  local -a _labels=()
  local _e
  for _e in "${_DRIVERS[@]}"; do
    _labels+=( "${_e%%|*}" )
  done

  msg2 "Which driver version do you want?"
  _default_index="$_DRIVER_LATEST_IDX"
  _prompt_from_array "${_labels[@]}"

  _e="${_DRIVERS[$_selected_index]}"
  local _br="${_e##*|}"

  case "$_br" in
    older)  _select_older_driver  ;;
    custom) _select_custom_driver ;;
    *)      _driver_version="$(_ver_from_entry "$_e")"; _driver_branch="$_br" ;;
  esac

  echo "_driver_version='$_driver_version'" >> "$_where/BIG_UGLY_FROGMINER"
  echo "_driver_branch='$_driver_branch'"   >> "$_where/BIG_UGLY_FROGMINER"
}

# DKMS mode
_set_dkms() {
  if [[ -n "${_dkms:-}" ]]; then
    echo "_dkms='$_dkms'" >> "$_where/BIG_UGLY_FROGMINER"
    return 0
  fi

  # build utils package only - no driver modules
  if [[ "${_build_utils_package_only:-false}" = "true" ]]; then
    _dkms="false"
    echo "_dkms='false'" >> "$_where/BIG_UGLY_FROGMINER"
    msg2 "_build_utils_package_only=true - forcing _dkms=false (kernel module not needed)."
    return 0
  fi

  local _dkms_choices=(
    "dkms (recommended)"
    "regular"
  )
  plain "Build the dkms package or the regular one?"
  _default_index=0
  _prompt_from_array "${_dkms_choices[@]}"
  if (( _selected_index == 0 )); then
    _dkms="true"
  else
    _dkms="false"
  fi
  echo "_dkms='$_dkms'" >> "$_where/BIG_UGLY_FROGMINER"
}

# Resolve open modules
_set_open_modules() {
  if [[ "${_open_source_modules:-}" = "false" ]]; then
    echo "_open_source_modules='false'" >> "$_where/BIG_UGLY_FROGMINER"
    return 0
  fi

  msg2 "Checking open driver availability..."
  local _xfree_url="https://download.nvidia.com/XFree86/NVIDIA-kernel-module-source/NVIDIA-kernel-module-source-${_driver_version}.tar.xz"
  local _github_url="https://codeload.github.com/NVIDIA/open-gpu-kernel-modules/tar.gz/refs/tags/${_driver_version}"
  local _xfree_status _github_status
  _xfree_status="$(curl -Is "$_xfree_url"  | head -n1)"
  _github_status="$(curl -Is "$_github_url" | head -n1)"

  if [[ "$_xfree_status" = *200* ]] || [[ "$_github_status" = *200* ]]; then
    if [[ -z "${_open_source_modules:-}" ]]; then
      msg2 "Open source kernel modules available for driver version $_driver_version."
      plain " ======================================================================="
      plain " RECOMMENDED for Turing (GTX 16xx / RTX 20xx) and newer."
      plain " NO SUPPORT FOR OLDER HARDWARE, unlike the proprietary driver package."
      plain " ======================================================================="
      msg2 "Do you want to use the proprietary driver to have support for older hardware?"
      local _prop_driver
      read -rp "    > N/y : " _prop_driver
      if [[ "$_prop_driver" =~ [yY] ]]; then
        _open_source_modules="false"
      else
        _open_source_modules="true"
      fi
    fi
    if [[ "$_xfree_status" = *200* ]]; then
      _srcbase="NVIDIA-kernel-module-source"
    else
      _srcbase="open-gpu-kernel-modules"
    fi
  else
    msg2 "No open source kernel module available"
    _open_source_modules="false"
  fi

  {
    echo "_open_source_modules='$_open_source_modules'"
    echo "_srcbase='${_srcbase:-}'"
  } >> "$_where/BIG_UGLY_FROGMINER"
}

# Check installed version is newer
_check_only_update() {
  [[ "${_only_update_if_newer:-}" != "true" ]] && return 0

  if pacman -Qs "nvidia-utils" >/dev/null 2>&1; then
    local _current_version _current_pkg
    _current_version=$(pacman -Q "nvidia-utils" | grep -oP '\d+(\.\d+)+' | head -n1)
    _current_pkg=$(pacman -Q "nvidia-utils" | grep -oP '[a-z]+(-[a-z]+)+' | head -n1)
    msg2 "Found version $_current_version installed (from package '$_current_pkg')"

    if [[ "$_driver_version" > "$_current_version" ]]; then
      msg2 "Selected ($_driver_version, $_driver_branch) is newer than installed version. Continuing."
    else
      msg2 "Selected ($_driver_version, $_driver_branch) is not newer than installed version. Exiting."
      plain ""
      if [[ -f "${_EXT_CONFIG_PATH:-}" ]]; then
        plain "If this is not intended, check '$_EXT_CONFIG_PATH'"
      else
        plain "If this is not intended, check '$_where/customization.cfg'"
      fi
      rm -f "$_where/BIG_UGLY_FROGMINER"
      exit 0
    fi
  else
    warning "'_only_update_if_newer' is enabled, but no installed driver found."
    warning "Continuing as if '_only_update_if_newer' was not enabled."
    plain ""
  fi
}

# Source name and URL
_set_source_name() {
  local _ver="$_driver_version"
  if [[ "$_driver_branch" = "vulkandev" ]]; then
    if (( ${_ver%%.*} >= 525 )); then
      _source_name="NVIDIA-Linux-x86_64-$_ver.run::https://developer.nvidia.com/downloads/vulkan-beta-${_ver//.}-linux"
    elif [[ $_ver = 396* ]]; then
      _source_name="NVIDIA-Linux-x86_64-$_ver.run::https://developer.nvidia.com/linux-${_ver//.}"
    else
      _source_name="NVIDIA-Linux-x86_64-$_ver.run::https://developer.nvidia.com/vulkan-beta-${_ver//.}-linux"
    fi
  else
    _source_name="https://us.download.nvidia.com/XFree86/Linux-x86_64/$_ver/NVIDIA-Linux-x86_64-$_ver.run"
  fi
  echo "_source_name='$_source_name'" >> "$_where/BIG_UGLY_FROGMINER"

  if [[ "$_open_source_modules" = "true" ]]; then
    if [[ "$_srcbase" = "NVIDIA-kernel-module-source" ]]; then
      _source_open="NVIDIA-kernel-module-source-${_ver}.tar.xz::https://download.nvidia.com/XFree86/NVIDIA-kernel-module-source/NVIDIA-kernel-module-source-${_ver}.tar.xz"
    elif [[ "$_srcbase" = "open-gpu-kernel-modules" ]]; then
      _source_open="open-gpu-kernel-modules-${_ver}.tar.gz::https://github.com/NVIDIA/open-gpu-kernel-modules/archive/refs/tags/${_ver}.tar.gz"
    fi
    echo "_source_open='$_source_open'" >> "$_where/BIG_UGLY_FROGMINER"
  fi

  if [[ "$_libxnvctrl" = "true" ]] && [[ "$_driver_branch" != "vulkandev" ]]; then
    _source_libxnvctrl="nvidia-settings-${_ver}.tar.gz::https://github.com/NVIDIA/nvidia-settings/archive/refs/tags/${_ver}.tar.gz"
    echo "_source_libxnvctrl='$_source_libxnvctrl'" >> "$_where/BIG_UGLY_FROGMINER"
  fi
}

# Resolve settings
_nv_initscript() {
  _set_driver_version
  _set_dkms
  _set_open_modules
  _check_only_update
  _set_source_name
  msg2 "Building driver version $_driver_version on branch $_driver_branch."
}

# Create symlinks
_create_links() {
  find "$pkgdir" -type f -name '*.so*' ! -path '*xorg/*' -print0 | while read -d $'\0' _lib; do
    [[ "$_lib" == *libnvidia-vulkan-producer.* ]] && continue
    local _dir _soname_name _soname _base
    _dir="$(dirname "${_lib}")"
    _soname_name="$(readelf -d "${_lib}" | grep -Po 'SONAME.*: \[\K[^]]*' || true)"
    [[ -z "$_soname_name" ]] && continue
    _soname="${_dir}/${_soname_name}"
    _base="${_dir}/$(echo "${_soname_name}" | sed -r 's/(.*)\.so.*/\1.so/')"
    [[ -e "${_soname}" ]] || ln -s "$(basename "${_lib}")" "${_soname}"
    [[ -e "${_base}" ]]   || ln -s "${_soname_name}" "${_base}"
  done
}

# List installed kernel
_detect_kernels() {
  local _path _kver
  local -a _candidates=()
  local -a _result=()
  local -A _seen=()

  # resolve _target_kernel package name to kernel version string
  if [ -n "${_target_kernel:-}" ]; then
    local _mod_dir _pkgbase_file _ver_file _resolved_kernel=""
    for _mod_dir in /usr/lib/modules/*/; do
      _pkgbase_file="${_mod_dir}pkgbase"
      if [ -f "$_pkgbase_file" ] && [ "$(cat "$_pkgbase_file")" = "$_target_kernel" ]; then
        _ver_file="${_mod_dir}build/version"
        [ -f "$_ver_file" ] || _ver_file="${_mod_dir}extramodules/version"
        if [ -f "$_ver_file" ]; then
          _resolved_kernel="$(cat "$_ver_file")"
          break
        fi
      fi
    done
    if [ -n "$_resolved_kernel" ]; then
      _kerneloverride="$_resolved_kernel"
      msg2 "_target_kernel '$_target_kernel' resolved to: $_kerneloverride" >&2
    else
      error "_target_kernel: no installed kernel found for package '$_target_kernel'. Is it installed with its headers?" >&2
      return 1
    fi
  fi

  if [ -n "${_kerneloverride:-}" ]; then
    _candidates=("$_kerneloverride")
  else
    if [ ! -t 0 ]; then
      while IFS= read -r _path; do
        case "$_path" in
          usr/lib/modules/*/vmlinuz | usr/lib/modules/*/extramodules/*)
            _kver="${_path#usr/lib/modules/}"
            _kver="${_kver%%/*}"
            _candidates+=("$_kver")
            ;;
        esac
      done
    fi

    while IFS= read -r _kver; do
      [ -n "$_kver" ] && _candidates+=("$_kver")
    done < <(
      find /usr/lib/modules/*/build/version       -exec cat {} + 2>/dev/null
      find /usr/lib/modules/*/extramodules/version -exec cat {} + 2>/dev/null
    )
  fi

  for _kver in "${_candidates[@]}"; do
    [ -n "$_kver" ] || continue
    if [ -n "${_seen[$_kver]:-}" ]; then
      continue
    fi
    _seen["$_kver"]=1

    if [ -d "/usr/lib/modules/$_kver/build" ]; then
      _result+=("$_kver")
    else
      warning "Skipping $_kver: missing /usr/lib/modules/$_kver/build" >&2
    fi
  done

  if [ ${#_result[@]} -eq 0 ]; then
    error "Could not detect buildable kernel version. Set _kerneloverride in customization.cfg." >&2
    return 1
  fi

  printf '%s\n' "${_result[@]}"
}

# Set BUILD_FLAGS
_build_flags() {
  local _kernel="$1"
  BUILD_FLAGS=()

  if grep -q "CONFIG_CC_IS_CLANG=y" "/usr/lib/modules/$_kernel/build/.config" 2>/dev/null; then
    BUILD_FLAGS+=(CC=clang LD=ld.lld LLVM=1 LLVM_IAS=1)
  fi
}

# _apply_patches TYPE [KERNEL]
# TYPE: open | dkms | closed
#   open   — ${srcdir}/${_srcbase}-${pkgver}
#   dkms   — ${srcdir}/${_pkg}
#   closed — ${srcdir}/${_pkg}/kernel-${_kernel}, or ${_pkg} if no kernel
_apply_patches() {
  local _type="$1"
  local _kernel="${2:-}"
  local _basedir
  case "$_type" in
    open) _basedir="${srcdir}/${_srcbase}-${pkgver}" ;;
    closed)
      if [[ -n "$_kernel" ]]; then
        _basedir="${srcdir}/${_pkg}/kernel-${_kernel}"
      else
        _basedir="${srcdir}/${_pkg}"
      fi
      ;;
    *)    _basedir="${srcdir}/${_pkg}" ;;
  esac
  local _list="${_where}/nvidia-all-patches/patches.list"

  [[ -f "$_list" ]] || { warning "_apply_patches: ${_list} not found, skipping"; return 0; }

  local _ptype _file _kmin _kmax _dmin _dmax _strip _tdir _flag _excl _rest
  while read -r _ptype _file _kmin _kmax _dmin _dmax _strip _tdir _flag _excl _rest || [[ -n "$_ptype" ]]; do
    [[ -z "$_ptype" || "$_ptype" == \#* ]] && continue
    [[ "$_ptype" != "$_type" ]] && continue

    # static vs per-kernel routing
    if [[ -z "$_kernel" ]]; then
      [[ "$_kmin" != "-" ]] && continue
    else
      [[ "$_kmin" == "-" ]] && continue
    fi

    # kernel version range
    if [[ -n "$_kernel" ]]; then
      [[ "$_kmin" != "-" ]] && (( $(vercmp "$_kernel" "$_kmin") < 0 )) && continue
      [[ "$_kmax" != "-" ]] && (( $(vercmp "$_kernel" "$_kmax") > 0 )) && continue
    fi

    # driver version range
    [[ "$_dmin" != "-" ]] && (( $(vercmp "$pkgver" "$_dmin") < 0 )) && continue
    [[ "$_dmax" != "-" ]] && (( $(vercmp "$pkgver" "$_dmax") > 0 )) && continue

    # exact driver version exclusion
    [[ -n "$_excl" && "$_excl" != "-" && "$pkgver" == "$_excl" ]] && continue

    # optional flag
    if [[ -n "$_flag" && "$_flag" != "-" ]]; then
      [[ "${!_flag:-}" != "true" ]] && continue
    fi

    local _apply_dir="${_basedir}"
    [[ "$_tdir" != "." && -n "$_tdir" ]] && _apply_dir="${_basedir}/${_tdir}"

    local _patch_file="${_where}/nvidia-all-patches/${_file}"
    if [[ ! -f "$_patch_file" ]]; then
      warning "_apply_patches: patch not found: ${_patch_file}"
      continue
    fi

    if [[ -n "$_kernel" ]]; then
      msg2 "Applying ${_file} (${_type}, kernel ${_kernel}, driver ${pkgver})..."
    else
      msg2 "Applying ${_file} (${_type}, driver ${pkgver})..."
    fi
    patch -Np"${_strip:-1}" -d "$_apply_dir" -i "$_patch_file"
  done < "$_list"
}

_nv_srcprep() {
  # reset logs dir
  rm -rf "$_where"/logs
  mkdir -p "$_where"/logs

  # copy system config files (udev, modprobe, etc.)
  local _f
  for _f in "$_where"/nvidia-all-config/system/*; do
    [[ -f "$_f" ]] || continue
    cp "$_f" "$_where"/
  done

  # remove previous build dir
  [ -d "$_pkg" ] && rm -rf "$_pkg"

  # Custom compiler paths
  if [ -n "${CUSTOM_GCC_PATH}" ]; then
    PATH=${CUSTOM_GCC_PATH}/bin:${CUSTOM_GCC_PATH}/lib:${CUSTOM_GCC_PATH}/include:${PATH}
  fi

  # GCC version check
  _system_gcc=$(gcc -dumpversion | cut -d. -f1)
  _kernel_gcc=$(grep -oP 'gcc \(GCC\) \K[0-9]+' /proc/version 2>/dev/null || \
                grep -oP 'gcc version \K[0-9]+' /proc/version 2>/dev/null || \
                grep -oP 'gcc-\K[0-9]+' /proc/version 2>/dev/null || \
                true)
  if [[ -n "$_kernel_gcc" && "$_system_gcc" != "$_kernel_gcc" ]]; then
    warning "========================================================================"
    warning "GCC VERSION MISMATCH DETECTED!"
    warning "Your system GCC: $_system_gcc"
    warning "Your running kernel was built with GCC: $_kernel_gcc"
    warning ""
    warning "NVIDIA modules must be compiled with the same GCC as the kernel."
    warning "Compilation may fail or cause issues!"
    warning ""
    warning "Either install GCC $_kernel_gcc or rebuild your kernel with GCC $_system_gcc"
    warning "========================================================================"
    plain ""
    read -p "    Continue anyway? [y/N] " _continue
    if [[ ! "$_continue" =~ [yY] ]]; then
      error "Aborted by user due to GCC mismatch."
      exit 1
    fi
  fi

  if [ "$_gcc14_fix" = "true" ] && [[ "$(gcc -dumpversion)" = 14* ]]; then
    _gcc14="true"
    msg2 "GCC 14 detected"
  elif [ "$_gcc15_fix" = "true" ] && [[ "$(gcc -dumpversion)" = 15* ]]; then
    _gcc15="true"
    msg2 "GCC 15 detected"
  fi

  # Extract
  msg2 "Self-Extracting $_pkg.run..."
  sh "$_pkg".run -x

  if [[ "$_libxnvctrl" = "true" ]] && [[ "$_driver_branch" != "vulkandev" ]]; then
    msg2 "Applying libxnvctrl_so.diff to nvidia-settings-${pkgver}..."
    patch -Np1 -d "${srcdir}/nvidia-settings-${pkgver}" -i "${_where}/nvidia-all-patches/all/nvidia-settings-libxnvctrl_so.diff"
  fi

  if [ "${_build_utils_package_only:-false}" = "true" ]; then
    msg2 "_build_utils_package_only=true - skipping kernel module prepare steps."
    cd "$srcdir/$_pkg"
    if [ -f nvidia-persistenced-init.tar.bz2 ]; then
      bsdtar -xf nvidia-persistenced-init.tar.bz2
    fi
    return 0
  fi

  if [ "$_open_source_modules" = "true" ]; then
    cd "${srcdir}/${_srcbase}-${pkgver}"

    # static open patches
    _apply_patches "open"

    # per-kernel open patches
    local -a _kernels
    mapfile -t _kernels < <(_detect_kernels)

    for _kernel in "${_kernels[@]}"; do
      _apply_patches "open" "$_kernel"
    done

    # GCC 15
    if [ "$_gcc15" = "true" ]; then
      local _gcc15_patch="${_where}/nvidia-all-patches/all/gcc-15.diff"
      msg2 "Applying gcc-15.diff to kernel-open (open source)..."
      ( cd kernel-open && patch -Np2 -i "$_gcc15_patch" )
      msg2 "Applying gcc-15.diff to kernel-open (closed driver copy)..."
      ( cd "$srcdir"/"$_pkg"/kernel-open && patch -Np2 -i "$_gcc15_patch" )
    fi

    # reproducible build
    sed -i "s/^HOSTNAME.*/HOSTNAME = echo archlinux"/ utils.mk
    sed -i "s/^WHOAMI.*/WHOAMI = echo archlinux-builder"/ utils.mk
    sed -i "s/^DATE.*/DATE = date -r version.mk"/ utils.mk

    shopt -s globstar
    for conf in "${srcdir}"/**/dkms.conf; do
      sed -i "s/__VERSION_STRING/${pkgver}/" "$conf"
      sed -i 's/__JOBS/`nproc`/' "$conf"
      sed -i 's/__EXCLUDE_MODULES//' "$conf"
      sed -i 's/__DKMS_MODULES//' "$conf"
      sed -i 's/NV_EXCLUDE_BUILD_MODULES/IGNORE_PREEMPT_RT_PRESENCE=1 NV_EXCLUDE_BUILD_MODULES/' "$conf"
      sed -i '$i\
BUILT_MODULE_NAME[0]="nvidia"\
DEST_MODULE_LOCATION[0]="/kernel/drivers/video"\
BUILT_MODULE_NAME[1]="nvidia-uvm"\
DEST_MODULE_LOCATION[1]="/kernel/drivers/video"\
BUILT_MODULE_NAME[2]="nvidia-modeset"\
DEST_MODULE_LOCATION[2]="/kernel/drivers/video"\
BUILT_MODULE_NAME[3]="nvidia-drm"\
DEST_MODULE_LOCATION[3]="/kernel/drivers/video"\
BUILT_MODULE_NAME[4]="nvidia-peermem"\
DEST_MODULE_LOCATION[4]="/kernel/drivers/video"' "$conf"
    done
    shopt -u globstar

    # kernel-open dkms.conf locations
    cat <<EOF >>"${srcdir}/${_srcbase}-${pkgver}/kernel-open/dkms.conf"
BUILT_MODULE_LOCATION[0]="kernel-open"
BUILT_MODULE_LOCATION[1]="kernel-open"
BUILT_MODULE_LOCATION[2]="kernel-open"
BUILT_MODULE_LOCATION[3]="kernel-open"
BUILT_MODULE_LOCATION[4]="kernel-open"
EOF

    # copy for DKMS
    cp -r ../${_srcbase}-${pkgver} "$srcdir"/open-gpu-kernel-modules-dkms

    cd "$srcdir/$_pkg"
    bsdtar -xf nvidia-persistenced-init.tar.bz2

  # closed-source module prep
  else
    cd "$_pkg"

    # linux-rt: bypass PREEMPT_RT check
    sed -i -e 's|PREEMPT_RT_PRESENT=1|PREEMPT_RT_PRESENT=0|g' kernel/conftest.sh

    # non-english locale workaround for 440.26
    if [[ $pkgver = 440.26 ]]; then
      sed -i -e 's|$CC $CFLAGS -c conftest_headers$$.c|LC_ALL=C $CC $CFLAGS -c conftest_headers$$.c|g' kernel/conftest.sh
    fi

    # 440.58.01 Unfrogging
    if [[ $pkgver = 440.58.01 ]]; then
      sed -i -e '/bug/d' nvidia-application-profiles-440.58.01-rc
    fi

    cp -a kernel kernel-dkms
    cd kernel-dkms
    sed -i "s/__VERSION_STRING/${pkgver}/" dkms.conf
    sed -i 's/__JOBS/`nproc`/' dkms.conf
    sed -i 's/__DKMS_MODULES//' dkms.conf
    if (( ${pkgver%%.*} >= 470 )); then
        sed -i '$iBUILT_MODULE_NAME[0]="nvidia"\
DEST_MODULE_LOCATION[0]="/kernel/drivers/video"\
BUILT_MODULE_NAME[1]="nvidia-uvm"\
DEST_MODULE_LOCATION[1]="/kernel/drivers/video"\
BUILT_MODULE_NAME[2]="nvidia-modeset"\
DEST_MODULE_LOCATION[2]="/kernel/drivers/video"\
BUILT_MODULE_NAME[3]="nvidia-drm"\
DEST_MODULE_LOCATION[3]="/kernel/drivers/video"\
BUILT_MODULE_NAME[4]="nvidia-peermem"\
DEST_MODULE_LOCATION[4]="/kernel/drivers/video"' dkms.conf
    elif (( ${pkgver%%.*} = 465 )); then
      sed -i '$iBUILT_MODULE_NAME[0]="nvidia"\
DEST_MODULE_LOCATION[0]="/kernel/drivers/video"\
BUILT_MODULE_NAME[1]="nvidia-uvm"\
DEST_MODULE_LOCATION[1]="/kernel/drivers/video"\
BUILT_MODULE_NAME[2]="nvidia-modeset"\
DEST_MODULE_LOCATION[2]="/kernel/drivers/video"\
BUILT_MODULE_NAME[3]="nvidia-drm"\
DEST_MODULE_LOCATION[3]="/kernel/drivers/video"\
BUILT_MODULE_NAME[4]="nvidia-peermem"\
DEST_MODULE_LOCATION[4]="/kernel/drivers/video"\
BUILT_MODULE_NAME[5]="nvidia-ib-peermem-stub"\
DEST_MODULE_LOCATION[5]="/kernel/drivers/video"' dkms.conf
    else
      sed -i '$iBUILT_MODULE_NAME[0]="nvidia"\
DEST_MODULE_LOCATION[0]="/kernel/drivers/video"\
BUILT_MODULE_NAME[1]="nvidia-uvm"\
DEST_MODULE_LOCATION[1]="/kernel/drivers/video"\
BUILT_MODULE_NAME[2]="nvidia-modeset"\
DEST_MODULE_LOCATION[2]="/kernel/drivers/video"\
BUILT_MODULE_NAME[3]="nvidia-drm"\
DEST_MODULE_LOCATION[3]="/kernel/drivers/video"' dkms.conf
    fi

    # Gift for linux-rt guys
    sed -i 's/NV_EXCLUDE_BUILD_MODULES/IGNORE_PREEMPT_RT_PRESENCE=1 NV_EXCLUDE_BUILD_MODULES/' dkms.conf

    cd ../
    bsdtar -xf nvidia-persistenced-init.tar.bz2

    if [[ $pkgver = 396* ]] || [[ $pkgver = 410* ]] || [[ $pkgver = 415* ]] || [[ $pkgver = 418* ]] || [[ $pkgver = 430* ]]; then
      sed -i 's/__NV_VK_ICD__/libGLX_nvidia.so.0/' nvidia_icd.json.template
    fi

    # per-kernel loop
    local -a _kernels
    mapfile -t _kernels < <(_detect_kernels)

    # static closed patches (applied once, before per-kernel copies)
    _apply_patches "closed"

    for _kernel in "${_kernels[@]}"; do
      cd "$srcdir"/"$_pkg"
      # separate source tree per kernel
      cp -r kernel kernel-"$_kernel"

      # closed per-kernel patches
      _apply_patches "closed" "$_kernel"

      # https://bugs.archlinux.org/task/62142
      if [ "$_62142_fix" = "true" ]; then
        sed -i 's/return (ops->map_resource != NULL);/return (ops \&\& ops->map_resource);/' "$srcdir/$_pkg/kernel-$_kernel/nvidia/nv-dma.c" && msg2 "Applied fix for https://bugs.archlinux.org/task/62142"
      fi

      # 5.1: vma_fault return type + list_is_first fix (< 418.56 drivers)
      if (( $(vercmp "$_kernel" "5.1") >= 0 )); then
        if [[ $pkgver != 430* ]]; then
          sed -i "s/static int nv_drm_vma_fault(struct vm_fault \*vmf)/#if LINUX_VERSION_CODE < KERNEL_VERSION(5, 1, 0)\nstatic int nv_drm_vma_fault(struct vm_fault \*vmf)\n#else\nstatic vm_fault_t nv_drm_vma_fault(struct vm_fault \*vmf)\n#endif/g" "$srcdir/$_pkg/kernel-$_kernel/nvidia-drm/nvidia-drm-gem-nvkms-memory.c"
          if [[ $pkgver = 396* ]] || [[ $pkgver = 410* ]] || [[ $pkgver = 415* ]] || [[ $pkgver = 418.3* ]] || [[ $pkgver = 418.4* ]]; then
            cd "$srcdir"/"$_pkg"/kernel-$_kernel
            msg2 "Applying list_is_first.diff for $_kernel..."
            # sed for the moving parts - Fix "redefinition of 'list_is_first'" (< 418.56 + 5.1+)
            sed -i "s/static inline int list_is_first(const struct list_head \*list,/#if LINUX_VERSION_CODE < KERNEL_VERSION(5, 1, 0)\nstatic inline int list_is_first(const struct list_head \*list,/g" "$srcdir/$_pkg/kernel-$_kernel/common/inc/nv-list-helpers.h"
            sed -i "s/                                const struct list_head \*head)/                                const struct list_head \*head)\n#else\nstatic inline int nv_list_is_first(const struct list_head \*list,\n                                   const struct list_head \*head)\n#endif/g" "$srcdir/$_pkg/kernel-$_kernel/common/inc/nv-list-helpers.h"
            patch -Np2 -i "${_where}/nvidia-all-patches/all/list_is_first.diff"
            cd ..
          fi
        fi
      fi

      cd ..

    done

    # dkms patches
    if [ "$_dkms" = "true" ]; then

      # https://bugs.archlinux.org/task/62142
      if [ "$_62142_fix" = "true" ]; then
        sed -i 's/return (ops->map_resource != NULL);/return (ops \&\& ops->map_resource);/' "$srcdir/$_pkg/kernel-dkms/nvidia/nv-dma.c" && msg2 "Applied fix for https://bugs.archlinux.org/task/62142"
      fi

      _apply_patches "dkms"
      for _kernel in "${_kernels[@]}"; do
        _apply_patches "dkms" "$_kernel"
      done

    fi
  fi
}

_nv_build() {
  if [ "$_libxnvctrl" = "true" ]; then
    msg2 "_libxnvctrl=true - building libXNVCtrl.so from nvidia-settings sources..."
    cd "$srcdir/nvidia-settings-$pkgver"
    make -C src PREFIX=/usr NV_USE_BUNDLED_LIBJANSSON=0 OUTPUTDIR=out out/libXNVCtrl.so
    cd "$srcdir"
  fi

  if [ "${_build_utils_package_only:-false}" = "true" ]; then
    msg2 "_build_utils_package_only=true - skipping kernel module build steps."
    return 0
  fi

  # skip for DKMS
  if [ "$_dkms" = "true" ]; then
    msg2 "_dkms=true - skipping kernel module build steps (handled by DKMS)."
    return 0
  fi

  if [ "$_open_source_modules" = "true" ]; then
    cd "${_srcbase}-${pkgver}"

    # per-kernel output dirs
    rm -rf "$srcdir/open-kmods"
    mkdir -p "$srcdir/open-kmods"
  fi

  local _kernel
  local -a _kernels
  mapfile -t _kernels < <(_detect_kernels)

  for _kernel in "${_kernels[@]}"; do
    _build_flags "$_kernel"

    local MODULE_FLAGS=(
      IGNORE_CC_MISMATCH=yes
      SYSSRC="/usr/lib/modules/$_kernel/build"
    )

    local _label="Nvidia"
    if [ "$_open_source_modules" = "true" ]; then
      _label="open NVIDIA"
    else
      cd "$srcdir"/$_pkg/kernel-$_kernel
    fi

    msg2 "Building $_label module for $_kernel..."
    CFLAGS= CXXFLAGS= LDFLAGS= make -j"$(nproc)" "${BUILD_FLAGS[@]}" "${MODULE_FLAGS[@]}" modules |& tee -a "$_where"/logs/build.log.txt
    local _make_status=${PIPESTATUS[0]}
    if (( _make_status != 0 )); then
      error "Building $_label module for $_kernel failed (exit ${_make_status})."
      return "${_make_status}"
    fi

    if [ "$_open_source_modules" = "true" ]; then
      local _open_kmods_dir="$srcdir/open-kmods/$_kernel"
      mkdir -p "$_open_kmods_dir"
      install -m644 -t "$_open_kmods_dir" kernel-open/*.ko
    fi
  done
}

# Clean on exit
function exit_cleanup {
  # remove flat-copied system files
  rm -f "${_where}"/*.diff
  rm -f "${_where}"/*.patch
  rm -f "${_where}"/*.conf
  rm -f "${_where}"/*.rules
  rm -f "${_where}"/*.sh
  rm -f "${_where}"/*.hook
  rm -f "${_where}"/*.install
  rm -f "${_where}"/*.dinit
  rm -f "${_where}"/*.sysusers
  rm -f "${_where}/cuda-no-stable-perf-limit"
  rm -f "${_where}/limit-vram-usage"
  rm -rf "${_where}/egl-wayland"

  # remove state tracker
  rm -f "$_where"/BIG_UGLY_FROGMINER

  # move packages to versioned dir
  if [ "${_local_package_storing:-}" = "true" ]; then
    rm -rf "${_where}/${pkgver}-packages" && \
      mkdir -p "${_where}/${pkgver}-packages" && \
      mv "${_where}/"*.pkg.* "${_where}/${pkgver}-packages"/ >/dev/null 2>&1
  fi

  # ensure logs dir exists (early failure)
  mkdir -p "${_where}/logs"

  # snapshot customization.cfg
  [[ -f "${_where}/customization.cfg" ]] && \
    cp -f "${_where}/customization.cfg" "${_where}/logs/customization.cfg.txt"

  # snapshot external config if present
  if [[ -n "${_EXT_CONFIG_PATH:-}" && -f "${_EXT_CONFIG_PATH}" ]]; then
    cp -f "${_EXT_CONFIG_PATH}" "${_where}/logs/ext_customization.cfg.txt"
  fi

  # move shell-output.log and strip ANSI codes
  if [[ -f "${_where}/shell-output.log" ]]; then
    mv -f "${_where}/shell-output.log" "${_where}/logs/shell-output.log.txt"
    sed -i 's/\x1b\[[0-9;]*m//g' "${_where}/logs/shell-output.log.txt"
    sed -i 's/\x1b(B//g' "${_where}/logs/shell-output.log.txt"
  fi

  # Create logs/system-info.txt
  {
    cat /etc/os-release
    echo "#################"
    echo "NVIDIA driver: ${_driver_version:-unknown} (${_driver_branch:-unknown})"
    echo "#################"
    gcc -v 2>&1
    if command -v clang &>/dev/null; then
      echo "#################"
      clang -v 2>&1
    fi
  } > "${_where}/logs/system-info.txt"

  remove_deps || ( true && msg2 "remove_deps not found" )

  msg2 'exit cleanup done'
}

trap exit_cleanup EXIT

# Check if the driver version supports open source modules.
_driver_supports_open_modules() {
  local _ver="$1"
  (( ${_ver%%.*} >= 515 ))
}

# Extract the version number from an EOL label
_ver_from_entry() {
  grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' <<< "${1#*:}" | head -1
}

if ! command -v vercmp &>/dev/null; then
  vercmp() {
    [[ "$1" == "$2" ]] && { echo 0; return; }
    local _newer
    _newer="$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)"
    [[ "${_newer}" == "$1" ]] && echo 1 || echo -1
  }
fi

